---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allGuides = await getCollection('guides');
const sorted = allGuides.sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());
---

<BaseLayout
  title="Buying Guides for College Students"
  description="In-depth buying guides to help college students choose the right tech. Laptops, headphones, tablets, and more — ranked and explained."
>
  <div class="container guides-index-wrap">
    <header class="page-header">
      <h1>Buying Guides</h1>
      <p>Not sure where to start? Our guides break down the best options for every budget and use case.</p>
    </header>

    <div class="guides-grid">
      {sorted.map(guide => (
        <a href={`/guides/${guide.slug}`} class="guide-card card">
          <div class="guide-img-wrap">
            <img src={guide.data.image} alt={guide.data.title} width="400" height="200" loading="lazy" />
          </div>
          <div class="guide-body">
            <span class="badge badge-blue">{guide.data.category}</span>
            <h2>{guide.data.title}</h2>
            <p>{guide.data.description}</p>
            <span class="guide-read">Read guide →</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .guides-index-wrap { padding: 2.5rem 1.25rem 4rem; }
  .page-header { margin-bottom: 2.5rem; }
  .page-header h1 { margin-bottom: 0.5rem; }
  .page-header p { font-size: 1.05rem; color: var(--text-muted); max-width: 60ch; margin: 0; }

  .guides-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .guide-card {
    text-decoration: none;
    color: var(--text);
    display: flex;
    flex-direction: column;
  }
  .guide-card:hover { text-decoration: none; color: var(--text); }
  .guide-img-wrap { overflow: hidden; }
  .guide-img-wrap img {
    width: 100%;
    height: 180px;
    object-fit: cover;
    transition: transform 0.3s ease;
  }
  .guide-card:hover .guide-img-wrap img { transform: scale(1.04); }
  .guide-body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }
  .guide-body h2 {
    font-size: 1.05rem;
    line-height: 1.3;
    color: var(--dark);
    margin: 0;
  }
  .guide-body p {
    font-size: 0.875rem;
    color: var(--text-muted);
    flex: 1;
    margin: 0;
    line-height: 1.5;
  }
  .guide-read {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--accent);
    margin-top: auto;
  }

  @media (max-width: 768px) { .guides-grid { grid-template-columns: 1fr; } }
  @media (min-width: 640px) and (max-width: 1024px) { .guides-grid { grid-template-columns: repeat(2, 1fr); } }
</style>
