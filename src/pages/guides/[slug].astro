---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const guides = await getCollection('guides');
  return guides.map(guide => ({
    params: { slug: guide.slug },
    props: { guide },
  }));
}

const { guide } = Astro.props;
const { Content } = await guide.render();
---

<BaseLayout
  title={guide.data.title}
  description={guide.data.description}
  ogImage={guide.data.image}
  type="article"
>
  <article class="container guide-wrap">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="breadcrumb-sep" aria-hidden="true">›</span>
      <a href="/guides">Guides</a>
      <span class="breadcrumb-sep" aria-hidden="true">›</span>
      <span aria-current="page">{guide.data.category}</span>
    </nav>

    <header class="guide-header">
      <span class="badge badge-blue">{guide.data.category}</span>
      <h1 class="mt-2">{guide.data.title}</h1>
      <p class="guide-desc mt-2">{guide.data.description}</p>
      <time class="guide-date" datetime={guide.data.publishDate.toISOString()}>
        Updated {guide.data.publishDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long' })}
      </time>
      <img
        src={guide.data.image}
        alt={guide.data.title}
        width="900"
        height="400"
        class="guide-hero-img mt-3"
        loading="eager"
      />
    </header>

    <div class="prose guide-prose">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  .guide-wrap { padding: 2.5rem 1.25rem 4rem; max-width: 860px; }
  .guide-desc { font-size: 1.1rem; color: var(--text-muted); line-height: 1.6; max-width: 64ch; }
  .guide-date { font-size: 0.85rem; color: var(--text-muted); display: block; margin-top: 0.5rem; }
  .guide-hero-img { width: 100%; height: 360px; object-fit: cover; border-radius: var(--radius-lg); border: 1px solid var(--border); }
  .guide-prose { margin-top: 2.5rem; }
</style>
