---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductCard from '../components/ProductCard.astro';
import AffiliateButton from '../components/AffiliateButton.astro';
import { getCollection } from 'astro:content';

const allReviews = await getCollection('reviews');
const featuredReviews = allReviews
  .filter(r => r.data.featured)
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

const latestReviews = allReviews
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 6);

const allGuides = await getCollection('guides');
const featuredGuides = allGuides
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 3);

const topPicks = [
  { name: 'Sony WH-1000XM5', tagline: 'Best study headphones', href: '/reviews/sony-wh-1000xm5', emoji: '🎧' },
  { name: 'AirPods Pro 2', tagline: 'Best ANC earbuds', href: '/reviews/apple-airpods-pro-2', emoji: '🎵' },
  { name: 'Logitech MX Keys Mini', tagline: 'Best wireless keyboard', href: '/reviews/logitech-mx-keys-mini', emoji: '⌨️' },
  { name: 'Samsung T7 SSD', tagline: 'Best portable storage', href: '/reviews/samsung-t7-portable-ssd', emoji: '💾' },
];
---

<BaseLayout
  title="Campus Tech — Honest Tech Reviews for College Students"
  description="Honest, budget-focused tech reviews for college students. We test laptops, headphones, keyboards, and gadgets so you can study smarter and spend less."
>
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="hero-content">
        <span class="hero-eyebrow badge badge-blue">Student-tested. Budget-approved.</span>
        <h1 class="hero-headline">Honest tech reviews for students who don't want to waste money.</h1>
        <p class="hero-sub">
          We buy, test, and honestly review laptops, headphones, keyboards, and gadgets
          so you can make the right call before clicking "Buy Now."
        </p>
        <div class="hero-ctas">
          <a href="/reviews" class="btn btn-primary btn-lg">Browse All Reviews</a>
          <a href="/guides" class="btn btn-outline btn-lg">Buying Guides</a>
        </div>
      </div>
      <div class="hero-art" aria-hidden="true">
        <div class="hero-blob">
          <div class="hero-icon-grid">
            <div class="hi hi-1">💻</div>
            <div class="hi hi-2">🎧</div>
            <div class="hi hi-3">⌨️</div>
            <div class="hi hi-4">📱</div>
            <div class="hi hi-5">🖱️</div>
            <div class="hi hi-6">💾</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Top Picks -->
  <section class="section section-picks">
    <div class="container">
      <div class="section-header">
        <h2>Top Picks Right Now</h2>
        <a href="/reviews" class="section-link">View all reviews →</a>
      </div>
      <div class="picks-grid">
        {topPicks.map(pick => (
          <a href={pick.href} class="pick-card">
            <span class="pick-emoji">{pick.emoji}</span>
            <div>
              <div class="pick-name">{pick.name}</div>
              <div class="pick-tagline">{pick.tagline}</div>
            </div>
            <svg width="16" height="16" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="pick-arrow">
              <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/>
            </svg>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Featured Reviews -->
  {featuredReviews.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="section-header">
          <h2>Featured Reviews</h2>
          <a href="/reviews" class="section-link">All reviews →</a>
        </div>
        <div class="grid grid-3">
          {featuredReviews.map(review => (
            <ProductCard
              name={review.data.title.split(':')[0]}
              image={review.data.image}
              rating={review.data.rating}
              verdict={review.data.verdict}
              price={review.data.price}
              category={review.data.category}
              slug={review.slug}
              asin={review.data.asin}
              affiliateUrl={review.data.affiliateUrl}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Latest Reviews -->
  <section class="section bg-secondary-section">
    <div class="container">
      <div class="section-header">
        <h2>Latest Reviews</h2>
        <a href="/reviews" class="section-link">All reviews →</a>
      </div>
      <div class="grid grid-3">
        {latestReviews.map(review => (
          <ProductCard
            name={review.data.title.split(':')[0]}
            image={review.data.image}
            rating={review.data.rating}
            verdict={review.data.verdict}
            price={review.data.price}
            category={review.data.category}
            slug={review.slug}
            asin={review.data.asin}
            affiliateUrl={review.data.affiliateUrl}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Guides promo -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2>Buying Guides</h2>
        <a href="/guides" class="section-link">All guides →</a>
      </div>
      <div class="guides-grid">
        {featuredGuides.map(guide => (
          <a href={`/guides/${guide.slug}`} class="guide-card card">
            <div class="guide-img-wrap">
              <img src={guide.data.image} alt={guide.data.title} width="400" height="200" loading="lazy" />
            </div>
            <div class="guide-body">
              <span class="badge badge-blue">{guide.data.category}</span>
              <h3>{guide.data.title}</h3>
              <p>{guide.data.description}</p>
              <span class="guide-cta">Read guide →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Trust strip -->
  <section class="trust-strip">
    <div class="container">
      <div class="trust-items">
        <div class="trust-item">
          <span class="trust-icon">🔬</span>
          <div>
            <strong>Hands-on tested</strong>
            <p>We buy and use every product we review</p>
          </div>
        </div>
        <div class="trust-item">
          <span class="trust-icon">💰</span>
          <div>
            <strong>Student budgets</strong>
            <p>Every review considers value for money</p>
          </div>
        </div>
        <div class="trust-item">
          <span class="trust-icon">🚫</span>
          <div>
            <strong>No sponsored reviews</strong>
            <p>We never accept payment for positive coverage</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .hero {
    background: linear-gradient(135deg, var(--primary) 0%, var(--dark) 100%);
    color: #fff;
    padding: 5rem 0;
    overflow: hidden;
  }
  .hero .container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }
  .hero-eyebrow { margin-bottom: 1rem; display: inline-block; }
  .hero-headline {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 900;
    color: #fff;
    line-height: 1.1;
    margin-bottom: 1.25rem;
  }
  .hero-sub {
    font-size: 1.1rem;
    color: rgba(255,255,255,0.8);
    max-width: 48ch;
    line-height: 1.65;
    margin-bottom: 2rem;
  }
  .hero-ctas { display: flex; gap: 1rem; flex-wrap: wrap; }
  .hero .btn-outline { color: #fff; border-color: rgba(255,255,255,0.4); }
  .hero .btn-outline:hover { background: rgba(255,255,255,0.1); color: #fff; }

  .hero-art { display: flex; justify-content: center; }
  .hero-blob {
    width: 300px;
    height: 300px;
    background: rgba(59,130,246,0.15);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .hero-icon-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    text-align: center;
  }
  .hi { font-size: 2.5rem; animation: float 3s ease-in-out infinite; }
  .hi-2 { animation-delay: 0.5s; }
  .hi-3 { animation-delay: 1s; }
  .hi-4 { animation-delay: 1.5s; }
  .hi-5 { animation-delay: 2s; }
  .hi-6 { animation-delay: 2.5s; }
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }

  /* Top Picks */
  .section-picks { background: var(--bg-secondary); }
  .picks-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }
  .pick-card {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1rem;
    text-decoration: none;
    color: var(--text);
    transition: all 0.15s;
  }
  .pick-card:hover {
    border-color: var(--accent);
    box-shadow: var(--shadow);
    transform: translateY(-2px);
    text-decoration: none;
    color: var(--text);
  }
  .pick-emoji { font-size: 1.75rem; flex-shrink: 0; }
  .pick-name { font-weight: 700; font-size: 0.9rem; }
  .pick-tagline { font-size: 0.78rem; color: var(--text-muted); }
  .pick-arrow { margin-left: auto; color: var(--text-muted); flex-shrink: 0; }

  /* Section header */
  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 1.75rem;
  }
  .section-link {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--accent);
  }

  /* Guides */
  .bg-secondary-section { background: var(--bg-secondary); }
  .guides-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  .guide-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: var(--text);
  }
  .guide-card:hover { text-decoration: none; color: var(--text); }
  .guide-img-wrap { overflow: hidden; }
  .guide-img-wrap img {
    width: 100%;
    height: 160px;
    object-fit: cover;
    transition: transform 0.3s ease;
  }
  .guide-card:hover .guide-img-wrap img { transform: scale(1.04); }
  .guide-body { padding: 1.25rem; flex: 1; display: flex; flex-direction: column; gap: 0.5rem; }
  .guide-body h3 { font-size: 1rem; margin: 0; }
  .guide-body p { font-size: 0.875rem; color: var(--text-muted); flex: 1; margin: 0; line-height: 1.5; }
  .guide-cta { font-size: 0.875rem; font-weight: 600; color: var(--accent); margin-top: auto; }

  /* Trust strip */
  .trust-strip {
    background: var(--primary);
    padding: 2.5rem 0;
  }
  .trust-items {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }
  .trust-item {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    color: rgba(255,255,255,0.9);
  }
  .trust-icon { font-size: 2rem; flex-shrink: 0; }
  .trust-item strong { display: block; color: #fff; margin-bottom: 0.25rem; }
  .trust-item p { font-size: 0.875rem; color: rgba(255,255,255,0.65); margin: 0; }

  @media (max-width: 1024px) {
    .picks-grid { grid-template-columns: repeat(2, 1fr); }
    .guides-grid { grid-template-columns: repeat(2, 1fr); }
    .trust-items { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 768px) {
    .hero .container { grid-template-columns: 1fr; }
    .hero-art { display: none; }
    .picks-grid { grid-template-columns: repeat(2, 1fr); }
    .guides-grid { grid-template-columns: 1fr; }
    .trust-items { grid-template-columns: 1fr; gap: 1.25rem; }
  }
  @media (max-width: 480px) {
    .picks-grid { grid-template-columns: 1fr; }
  }
</style>
