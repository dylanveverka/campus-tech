---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import { getCollection } from 'astro:content';

const allReviews = await getCollection('reviews');
const allGuides  = await getCollection('guides');

// Unified article feed — reviews + guides, newest first
const allArticles = [
  ...allReviews.map(r => ({
    slug:        r.slug,
    type:        'review' as const,
    href:        `/reviews/${r.slug}`,
    name:        r.data.title.split(':')[0],
    image:       r.data.image,
    category:    r.data.category,
    rating:      r.data.rating,
    verdict:     r.data.verdict,
    price:       r.data.price,
    asin:        r.data.asin,
    affiliateUrl: r.data.affiliateUrl,
    publishDate: r.data.publishDate,
  })),
  ...allGuides.map(g => ({
    slug:        g.slug,
    type:        'guide' as const,
    href:        `/guides/${g.slug}`,
    name:        g.data.title,
    image:       g.data.image,
    category:    g.data.category,
    description: g.data.description,
    publishDate: g.data.publishDate,
  })),
].sort((a, b) => b.publishDate.getTime() - a.publishDate.getTime());

const categories = [...new Set(allArticles.map(a => a.category))].sort();
const total = allArticles.length;
---

<BaseLayout
  title="All Articles — Campus Tech"
  description="Every review, roundup, and buying guide on Campus Tech. Laptops, headphones, tablets, keyboards, and more — all tested for college students."
>
  <div class="container reviews-wrap">
    <header class="page-header">
      <h1>All Articles</h1>
      <p>
        {total} reviews and guides — tested for college students, focused on value for money.
      </p>
    </header>

    <div class="category-filter" role="navigation" aria-label="Filter by category">
      <button class="filter-btn active" data-filter="all">All ({total})</button>
      {categories.map(cat => {
        const count = allArticles.filter(a => a.category === cat).length;
        return (
          <button class="filter-btn" data-filter={cat.toLowerCase()}>
            {cat} ({count})
          </button>
        );
      })}
    </div>

    <div class="grid grid-3 mt-4" id="articles-grid">
      {allArticles.map(article => (
        <div class="article-item" data-cat={article.category.toLowerCase()}>
          {'rating' in article ? (
            <ProductCard
              name={article.name}
              image={article.image}
              category={article.category}
              slug={article.slug}
              href={article.href}
              rating={article.rating}
              verdict={article.verdict}
              price={article.price}
              asin={article.asin}
              affiliateUrl={article.affiliateUrl}
            />
          ) : (
            <ProductCard
              name={article.name}
              image={article.image}
              category={article.category}
              slug={article.slug}
              href={article.href}
              description={article.description}
            />
          )}
        </div>
      ))}
    </div>

    <p class="no-results" id="no-results" hidden>No articles found in this category.</p>
  </div>
</BaseLayout>

<style>
  .reviews-wrap { padding: 2.5rem 1.25rem 4rem; }
  .page-header { margin-bottom: 2rem; }
  .page-header h1 { margin-bottom: 0.4rem; }
  .page-header p { font-size: 1.05rem; color: var(--text-muted); max-width: 60ch; margin: 0; }

  .category-filter {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }
  .filter-btn {
    padding: 0.35rem 0.9rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-muted);
    background: var(--bg);
    cursor: pointer;
    transition: all 0.15s;
    font-family: var(--font-sans);
  }
  .filter-btn:hover {
    border-color: var(--primary);
    color: var(--primary);
  }
  .filter-btn.active {
    background: var(--primary);
    border-color: var(--primary);
    color: #fff;
  }

  .article-item { display: contents; }
  .article-item.hidden { display: none; }

  .no-results {
    text-align: center;
    color: var(--text-muted);
    padding: 3rem 0;
    font-size: 1rem;
  }
</style>

<script>
  const buttons  = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const items    = document.querySelectorAll<HTMLElement>('.article-item');
  const noResults = document.getElementById('no-results') as HTMLElement;

  function applyFilter(cat: string) {
    let visible = 0;
    items.forEach(item => {
      const match = cat === 'all' || item.dataset.cat === cat;
      item.classList.toggle('hidden', !match);
      if (match) visible++;
    });
    noResults.hidden = visible > 0;
    buttons.forEach(btn => {
      btn.classList.toggle('active', btn.dataset.filter === cat);
    });
    const url = new URL(window.location.href);
    if (cat === 'all') url.searchParams.delete('category');
    else url.searchParams.set('category', cat);
    history.replaceState(null, '', url.toString());
  }

  buttons.forEach(btn => btn.addEventListener('click', () => applyFilter(btn.dataset.filter ?? 'all')));

  const init = new URL(window.location.href).searchParams.get('category');
  if (init) applyFilter(init);
</script>
