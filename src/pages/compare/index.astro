---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const comparisons = await getCollection('compare');
const sorted = comparisons.sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());
---

<BaseLayout
  title="Tech Comparisons for College Students"
  description="Side-by-side tech comparisons for college students. MacBook vs Dell, iPad vs laptop, and more — with a clear winner and honest analysis."
>
  <div class="container compare-index-wrap">
    <header class="page-header">
      <h1>Compare Products</h1>
      <p>Can't decide between two products? We put them head-to-head so you don't have to guess.</p>
    </header>

    <div class="compare-list">
      {sorted.map(comp => (
        <a href={`/compare/${comp.slug}`} class="compare-card card">
          <div class="compare-vs">
            <div class="compare-product-thumb">
              {comp.data.product1.image
                ? <img src={comp.data.product1.image} alt={comp.data.product1.name} width="120" height="80" loading="lazy" />
                : <div class="thumb-placeholder">{comp.data.product1.name[0]}</div>
              }
              <span>{comp.data.product1.name}</span>
            </div>
            <div class="vs-badge">VS</div>
            <div class="compare-product-thumb">
              {comp.data.product2.image
                ? <img src={comp.data.product2.image} alt={comp.data.product2.name} width="120" height="80" loading="lazy" />
                : <div class="thumb-placeholder">{comp.data.product2.name[0]}</div>
              }
              <span>{comp.data.product2.name}</span>
            </div>
          </div>
          <div class="compare-card-body">
            <h2>{comp.data.title}</h2>
            <p>{comp.data.description}</p>
            <div class="compare-footer">
              <span class="winner-tag">
                <svg width="14" height="14" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                Winner: <strong>{comp.data.winner}</strong>
              </span>
              <span class="compare-read">Read comparison →</span>
            </div>
          </div>
        </a>
      ))}
    </div>

    <div class="compare-cta">
      <p>Don't see the comparison you're looking for? <a href="/contact">Let us know</a> and we'll add it.</p>
    </div>
  </div>
</BaseLayout>

<style>
  .compare-index-wrap { padding: 2.5rem 1.25rem 4rem; }
  .page-header { margin-bottom: 2.5rem; }
  .page-header h1 { margin-bottom: 0.5rem; }
  .page-header p { font-size: 1.05rem; color: var(--text-muted); max-width: 60ch; margin: 0; }

  .compare-list { display: flex; flex-direction: column; gap: 1.25rem; max-width: 860px; }

  .compare-card {
    display: grid;
    grid-template-columns: 320px 1fr;
    text-decoration: none;
    color: var(--text);
    transition: box-shadow 0.2s, transform 0.2s;
  }
  .compare-card:hover { text-decoration: none; color: var(--text); }

  .compare-vs {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1.5rem;
    background: var(--bg-secondary);
    border-right: 1px solid var(--border);
  }
  .compare-product-thumb {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    flex: 1;
    min-width: 0;
  }
  .compare-product-thumb img {
    width: 80px;
    height: 55px;
    object-fit: contain;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    background: #fff;
    padding: 4px;
  }
  .thumb-placeholder {
    width: 80px;
    height: 55px;
    background: var(--primary);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    font-weight: 700;
    border-radius: var(--radius);
  }
  .compare-product-thumb span {
    font-size: 0.75rem;
    font-weight: 600;
    text-align: center;
    line-height: 1.2;
    color: var(--text);
  }
  .vs-badge {
    background: var(--dark);
    color: #fff;
    font-size: 0.75rem;
    font-weight: 900;
    padding: 0.3rem 0.5rem;
    border-radius: 6px;
    flex-shrink: 0;
    letter-spacing: 0.05em;
  }

  .compare-card-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .compare-card-body h2 {
    font-size: 1.05rem;
    font-weight: 700;
    line-height: 1.3;
    color: var(--dark);
    margin: 0;
  }
  .compare-card-body p {
    font-size: 0.875rem;
    color: var(--text-muted);
    flex: 1;
    margin: 0;
    line-height: 1.5;
  }
  .compare-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.875rem;
    margin-top: 0.5rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--border);
    gap: 0.5rem;
  }
  .winner-tag {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    color: #166534;
    font-size: 0.85rem;
  }
  .winner-tag svg { color: #16a34a; flex-shrink: 0; }
  .winner-tag strong { color: var(--primary); }
  .compare-read {
    color: var(--accent);
    font-weight: 600;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .compare-cta {
    margin-top: 2.5rem;
    font-size: 0.95rem;
    color: var(--text-muted);
    max-width: 860px;
  }
  .compare-cta a { font-weight: 600; }

  @media (max-width: 640px) {
    .compare-card { grid-template-columns: 1fr; }
    .compare-vs { border-right: none; border-bottom: 1px solid var(--border); padding: 1rem; }
    .compare-card-body { padding: 1rem; }
  }
</style>
