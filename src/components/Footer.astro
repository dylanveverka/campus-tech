---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" class="footer-logo">
          <svg width="24" height="24" viewBox="0 0 32 32" fill="none" aria-hidden="true">
            <rect width="32" height="32" rx="6" fill="#3b82f6"/>
            <text x="16" y="22" font-family="Arial, sans-serif" font-size="18" font-weight="bold"
                  text-anchor="middle" fill="#fff">C</text>
          </svg>
          <span>Campus<span class="accent">Tech</span></span>
        </a>
        <p class="footer-tagline">Honest tech reviews for students who don't want to waste money.</p>
      </div>

      <nav class="footer-nav" aria-label="Footer navigation">
        <div class="footer-col">
          <h3>Reviews</h3>
          <ul>
            <li><a href="/reviews">All Reviews</a></li>
            <li><a href="/reviews?category=laptops">Laptops</a></li>
            <li><a href="/reviews?category=headphones">Headphones</a></li>
            <li><a href="/reviews?category=keyboards">Keyboards</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h3>Resources</h3>
          <ul>
            <li><a href="/guides">Buying Guides</a></li>
            <li><a href="/compare">Comparisons</a></li>
            <li><a href="/about">About Us</a></li>
            <li><a href="/contact">Contact</a></li>
          </ul>
        </div>
      </nav>
    </div>

    <div class="footer-disclosure">
      <h4>Affiliate Disclosure</h4>
      <p>
        Campus Tech participates in the Amazon Services LLC Associates Program and other affiliate
        advertising programs. When you click our affiliate links and make a purchase, we may earn a
        small commission at no additional cost to you. This helps us keep the site free and our
        reviews independent. We only recommend products we've genuinely tested and believe in.
        Our editorial opinions are never influenced by affiliate relationships.
      </p>
    </div>

    <div class="footer-bottom">
      <p>&copy; {year} Campus Tech. All rights reserved.</p>
      <p class="footer-legal">
        <a href="/about">About</a> &middot;
        <a href="/contact">Contact</a> &middot;
        <a href="/privacy">Privacy Policy</a>
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--dark);
    color: rgba(255,255,255,0.75);
    padding: 3rem 0 1.5rem;
    margin-top: 4rem;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 3rem;
    margin-bottom: 2.5rem;
  }
  .footer-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: #fff;
    font-size: 1.2rem;
    font-weight: 800;
    text-decoration: none;
    margin-bottom: 0.75rem;
  }
  .footer-logo .accent { color: #93c5fd; }
  .footer-tagline { font-size: 0.875rem; line-height: 1.5; max-width: 26ch; }
  .footer-nav {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }
  .footer-col h3 {
    color: #fff;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.75rem;
  }
  .footer-col ul { list-style: none; }
  .footer-col li { margin-bottom: 0.5rem; }
  .footer-col a {
    color: rgba(255,255,255,0.65);
    font-size: 0.9rem;
    text-decoration: none;
    transition: color 0.15s;
  }
  .footer-col a:hover { color: #93c5fd; text-decoration: none; }
  .footer-disclosure {
    border-top: 1px solid rgba(255,255,255,0.08);
    border-bottom: 1px solid rgba(255,255,255,0.08);
    padding: 1.5rem 0;
    margin-bottom: 1.5rem;
  }
  .footer-disclosure h4 {
    color: rgba(255,255,255,0.5);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.5rem;
  }
  .footer-disclosure p {
    font-size: 0.8rem;
    line-height: 1.6;
    color: rgba(255,255,255,0.45);
    margin: 0;
  }
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.8rem;
    color: rgba(255,255,255,0.35);
  }
  .footer-legal a {
    color: rgba(255,255,255,0.35);
    text-decoration: none;
  }
  .footer-legal a:hover { color: rgba(255,255,255,0.65); }

  @media (max-width: 768px) {
    .footer-grid { grid-template-columns: 1fr; gap: 2rem; }
    .footer-bottom { flex-direction: column; gap: 0.5rem; text-align: center; }
  }
</style>
