---
interface Props {
  pros: string[];
  cons: string[];
}

const { pros, cons } = Astro.props;
---

<div class="pros-cons">
  <div class="pros-box">
    <h3 class="pros-heading">
      <svg width="18" height="18" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
      </svg>
      Pros
    </h3>
    <ul class="pros-list">
      {pros.map(pro => (
        <li>
          <svg width="14" height="14" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
          </svg>
          {pro}
        </li>
      ))}
    </ul>
  </div>

  <div class="cons-box">
    <h3 class="cons-heading">
      <svg width="18" height="18" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
      </svg>
      Cons
    </h3>
    <ul class="cons-list">
      {cons.map(con => (
        <li>
          <svg width="14" height="14" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/>
          </svg>
          {con}
        </li>
      ))}
    </ul>
  </div>
</div>

<style>
  .pros-cons {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
    margin: 1.5rem 0;
  }
  .pros-box, .cons-box {
    border-radius: var(--radius-lg);
    padding: 1.25rem;
  }
  .pros-box {
    background: #f0fdf4;
    border: 1px solid #bbf7d0;
  }
  .cons-box {
    background: #fff1f2;
    border: 1px solid #fecdd3;
  }
  .pros-heading, .cons-heading {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 1rem;
    margin-bottom: 0.75rem;
  }
  .pros-heading { color: #166534; }
  .cons-heading { color: #9f1239; }
  .pros-list, .cons-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .pros-list li, .cons-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: 0.9rem;
    line-height: 1.45;
  }
  .pros-list li svg { color: #16a34a; flex-shrink: 0; margin-top: 2px; }
  .cons-list li svg { color: #dc2626; flex-shrink: 0; margin-top: 2px; }

  @media (max-width: 600px) {
    .pros-cons { grid-template-columns: 1fr; }
  }
</style>
