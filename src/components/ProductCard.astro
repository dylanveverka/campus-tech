---
import StarRating from './StarRating.astro';
import AffiliateButton from './AffiliateButton.astro';

interface Props {
  name: string;
  image: string;
  category: string;
  slug: string;
  href?: string;        // full path override — use for guides (/guides/slug)
  description?: string; // guide description fallback when no verdict
  rating?: number;      // optional — guides don't have ratings
  verdict?: string;     // optional — falls back to description
  price?: string;       // optional — guides don't have prices
  asin?: string;
  affiliateUrl?: string;
}

const {
  name, image, category, slug,
  href, description,
  rating, verdict, price,
  asin, affiliateUrl,
} = Astro.props;

const link = href ?? `/reviews/${slug}`;
const blurb = verdict ?? description ?? '';
const isReview = rating !== undefined;
---

<article class="product-card card">
  <a href={link} class="card-image-link" tabindex="-1" aria-hidden="true">
    <img src={image} alt={name} width="400" height="225" loading="lazy" />
  </a>
  <div class="card-body">
    <div class="card-top">
      <span class:list={['badge', isReview ? 'badge-blue' : 'badge-green']}>{category}</span>
      {!isReview && <span class="guide-label">Guide</span>}
    </div>
    <h3 class="card-title">
      <a href={link}>{name}</a>
    </h3>
    {isReview && (
      <div class="card-rating">
        <StarRating rating={rating!} size="sm" showNumber={true} />
      </div>
    )}
    <p class="card-verdict">{blurb}</p>
    <div class="card-actions">
      <a href={link} class="read-link">
        {isReview ? 'Read full review →' : 'Read guide →'}
      </a>
      {isReview && (asin || affiliateUrl) && (
        <AffiliateButton asin={asin} href={affiliateUrl} size="sm" text="Check Price" />
      )}
    </div>
  </div>
</article>

<style>
  .product-card { display: flex; flex-direction: column; height: 100%; }
  .card-image-link { display: block; overflow: hidden; }
  .card-image-link img {
    width: 100%;
    aspect-ratio: 16/9;
    object-fit: cover;
    transition: transform 0.3s ease;
  }
  .product-card:hover .card-image-link img { transform: scale(1.04); }
  .card-body {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: 1.25rem;
    gap: 0.5rem;
  }
  .card-top {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .guide-label {
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .card-title {
    font-size: 1.05rem;
    font-weight: 700;
    line-height: 1.3;
    margin: 0;
  }
  .card-title a { color: var(--dark); text-decoration: none; }
  .card-title a:hover { color: var(--accent); text-decoration: none; }
  .card-rating { display: flex; align-items: center; }
  .card-verdict {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.5;
    flex: 1;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card-actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 0.75rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--border);
    gap: 0.5rem;
  }
  .read-link {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--accent);
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .read-link:hover { text-decoration: underline; }
</style>
