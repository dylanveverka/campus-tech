---
import StarRating from './StarRating.astro';
import AffiliateButton from './AffiliateButton.astro';

interface Props {
  name: string;
  image: string;
  rating: number;
  verdict: string;
  price: string;
  category: string;
  slug: string;
  asin?: string;
  affiliateUrl?: string;
}

const { name, image, rating, verdict, price, category, slug, asin, affiliateUrl } = Astro.props;
---

<article class="product-card card">
  <a href={`/reviews/${slug}`} class="card-image-link" tabindex="-1" aria-hidden="true">
    <img src={image} alt={name} width="400" height="225" loading="lazy" />
  </a>
  <div class="card-body">
    <div class="card-top">
      <span class="badge badge-blue card-category">{category}</span>
    </div>
    <h3 class="card-title">
      <a href={`/reviews/${slug}`}>{name}</a>
    </h3>
    <div class="card-rating">
      <StarRating rating={rating} size="sm" showNumber={true} />
    </div>
    <p class="card-verdict">{verdict}</p>
    <div class="card-actions">
      <a href={`/reviews/${slug}`} class="read-link">Read full review →</a>
      <AffiliateButton asin={asin} href={affiliateUrl} size="sm" text="Check Price" />
    </div>
  </div>
</article>

<style>
  .product-card { display: flex; flex-direction: column; height: 100%; }
  .card-image-link { display: block; overflow: hidden; }
  .card-image-link img {
    width: 100%;
    aspect-ratio: 16/9;
    object-fit: cover;
    transition: transform 0.3s ease;
  }
  .product-card:hover .card-image-link img { transform: scale(1.04); }
  .card-body {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: 1.25rem;
    gap: 0.5rem;
  }
  .card-top { display: flex; align-items: center; justify-content: space-between; }
  .card-category { }
  .card-title {
    font-size: 1.05rem;
    font-weight: 700;
    line-height: 1.3;
    margin: 0;
  }
  .card-title a { color: var(--dark); text-decoration: none; }
  .card-title a:hover { color: var(--accent); text-decoration: none; }
  .card-rating { display: flex; align-items: center; }
  .card-verdict {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.5;
    flex: 1;
    margin: 0;
  }
  .card-actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 0.75rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--border);
    gap: 0.5rem;
  }
  .read-link {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--accent);
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .read-link:hover { text-decoration: underline; }
</style>
