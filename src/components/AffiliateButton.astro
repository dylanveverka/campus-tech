---
import { amazonLink } from '../utils/affiliate';

interface Props {
  href?: string;
  asin?: string;
  text?: string;
  size?: 'sm' | 'md' | 'lg';
  variant?: 'primary' | 'amazon';
}

const {
  href,
  asin,
  text = 'Check Price on Amazon',
  size = 'md',
  variant = 'amazon',
} = Astro.props;

const url = href ?? (asin ? amazonLink(asin) : '#');
---

<a
  href={url}
  target="_blank"
  rel="nofollow sponsored noopener noreferrer"
  class:list={['affiliate-btn', `btn-${size}`, `btn-${variant}`]}
>
  {variant === 'amazon' && (
    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M18.42 14.58c-.29.19-.71.19-1.04.02-1.46-1.22-1.72-1.78-2.52-2.94-2.41 2.46-4.12 3.2-7.24 3.2-3.69 0-6.56-2.27-6.56-6.83 0-3.56 1.93-5.98 4.69-7.16 2.39-1.04 5.73-1.22 8.28-1.51V.85c0-.98.08-2.14-.5-2.99-.5-.76-1.47-1.07-2.32-1.07-1.58 0-2.99.81-3.33 2.49-.07.37-.36.73-.74.75l-4.12-.44c-.35-.08-.74-.36-.64-.89C3.4.78 6.94-1 10.83-1c1.98 0 4.57.53 6.13 2.03C18.74 2.75 18.5 5 18.5 7.5v6.8c0 .93.39 1.34.75 1.84.13.18.16.39-.01.52l-2.82 2.42-.01.01-.02-.01zM14.33 9.43c0-1.72.04-3.15-.83-4.67-.7-1.24-1.82-2-3.07-2-1.7 0-2.7 1.3-2.7 3.22 0 4.3 3.96 5.08 6.6 5.08V9.43z"/>
    </svg>
  )}
  {text}
  <svg width="14" height="14" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
    <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/>
  </svg>
</a>

<style>
  .affiliate-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-weight: 700;
    border-radius: var(--radius);
    text-decoration: none;
    transition: all 0.15s ease;
    white-space: nowrap;
  }
  .btn-sm { padding: 0.4rem 0.9rem; font-size: 0.85rem; }
  .btn-md { padding: 0.65rem 1.25rem; font-size: 0.95rem; }
  .btn-lg { padding: 0.85rem 1.75rem; font-size: 1.05rem; }

  .btn-amazon {
    background: #ff9900;
    color: #111;
  }
  .btn-amazon:hover {
    background: #e68a00;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgb(255 153 0 / 0.35);
    text-decoration: none;
    color: #111;
  }
  .btn-primary {
    background: var(--accent);
    color: #fff;
  }
  .btn-primary:hover {
    background: var(--accent-hover);
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgb(59 130 246 / 0.35);
    text-decoration: none;
    color: #fff;
  }
</style>
